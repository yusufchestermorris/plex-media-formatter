# Metadata provider: "jikan" or "tmdb"
API_CLIENT=jikan

# Optional override. Leave blank to use the built-in default for the selected API client.
# Jikan default: https://api.jikan.moe/v4
# TMDB default:  https://api.themoviedb.org/3
API_URL=

# Required only when API_CLIENT=tmdb
API_KEY=

# Root Plex TV library path
PLEX_LIBRARY_ROOT=/mnt/plex/media

# Optional override. Leave blank to default to PLEX_LIBRARY_ROOT/manifest.json
MANIFEST_PATH=

# Optional override. Leave blank to default to PLEX_LIBRARY_ROOT/latest_manifest.txt
LATEST_MANIFEST_PATH=
